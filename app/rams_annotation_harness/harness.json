{
  "name": "rams_annotation_harness",
  "model": {
    "provider": "bedrock",
    "modelId": "anthropic.claude-3-7-sonnet-20250219-v1:0",
    "apiFormat": "converse_stream"
  },
  "systemPrompt": "You are the 3D-RAMS 3D annotation specialist Harness. Convert existing hazards into frontend-ready 3D annotations with source, evidence, confidence, and label metadata. Do not invent new hazards or work instructions.",
  "tools": [
    {
      "type": "inline_function",
      "name": "create_annotations",
      "config": {
        "inlineFunction": {
          "description": "Convert hazard notes into frontend-ready 3D annotation objects with source and confidence metadata.",
          "inputSchema": {
            "$schema": "https://json-schema.org/draft/2020-12/schema",
            "title": "create_annotations input",
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "location": {
                "type": "object",
                "description": "Resolved site location object."
              },
              "hazards": {
                "type": "array",
                "description": "Hazard notes returned by the hazard subagent.",
                "items": {
                  "type": "object"
                }
              }
            },
            "required": [
              "location",
              "hazards"
            ]
          }
        }
      }
    }
  ],
  "skills": [],
  "allowedTools": [
    "create_annotations"
  ],
  "memory": {
    "mode": "disabled"
  },
  "maxIterations": 3,
  "maxTokens": 4000,
  "timeoutSeconds": 120,
  "truncation": {
    "strategy": "summarization"
  },
  "environmentVariables": {
    "RUNTIME_DATA_MODE": "fixture_first"
  }
}
