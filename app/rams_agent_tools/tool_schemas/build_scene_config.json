{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "build_scene_config input",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "location": {
      "type": "object",
      "description": "Resolved site location object."
    },
    "features": {
      "type": "array",
      "description": "Geospatial feature objects returned by load_geospatial_features.",
      "items": {
        "type": "object"
      }
    },
    "fixturePack": {
      "type": ["string", "null"],
      "description": "Optional cached fixture pack id."
    }
  },
  "required": ["location", "features"]
}
