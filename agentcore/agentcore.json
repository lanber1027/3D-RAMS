{
  "$schema": "https://schema.agentcore.aws.dev/v1/agentcore.json",
  "name": "RamsAgent",
  "version": 1,
  "managedBy": "CDK",
  "tags": {
    "agentcore:created-by": "agentcore-cli",
    "agentcore:project-name": "RamsAgent"
  },
  "runtimes": [
    {
      "name": "rams_supervisor_runtime",
      "build": "CodeZip",
      "entrypoint": "main.py",
      "codeLocation": "app/rams_supervisor_runtime/",
      "runtimeVersion": "PYTHON_3_14",
      "networkMode": "PUBLIC",
      "protocol": "HTTP"
    },
    {
      "name": "asi_one_entry_agent",
      "build": "CodeZip",
      "entrypoint": "main.py",
      "codeLocation": "app/asi_one_entry_agent/",
      "runtimeVersion": "PYTHON_3_14",
      "networkMode": "PUBLIC",
      "protocol": "HTTP"
    }
  ],
  "memories": [
    {
      "name": "asi_one_entry_agent_memory",
      "eventExpiryDuration": 30,
      "strategies": [
        {
          "type": "SEMANTIC",
          "namespaceTemplates": [
            "/users/{actorId}/facts"
          ]
        },
        {
          "type": "USER_PREFERENCE",
          "namespaceTemplates": [
            "/users/{actorId}/preferences"
          ]
        },
        {
          "type": "SUMMARIZATION",
          "namespaceTemplates": [
            "/summaries/{actorId}/{sessionId}"
          ]
        },
        {
          "type": "EPISODIC",
          "namespaceTemplates": [
            "/episodes/{actorId}/{sessionId}"
          ],
          "reflectionNamespaceTemplates": [
            "/episodes/{actorId}"
          ]
        }
      ]
    }
  ],
  "knowledgeBases": [],
  "credentials": [],
  "evaluators": [],
  "onlineEvalConfigs": [],
  "agentCoreGateways": [],
  "policyEngines": [],
  "configBundles": [],
  "abTests": [],
  "harnesses": [
    {
      "name": "rams_supervisor_harness",
      "path": "app/rams_supervisor_harness"
    },
    {
      "name": "rams_geospatial_harness",
      "path": "app/rams_geospatial_harness"
    },
    {
      "name": "rams_planning_harness",
      "path": "app/rams_planning_harness"
    },
    {
      "name": "rams_hazard_harness",
      "path": "app/rams_hazard_harness"
    },
    {
      "name": "rams_open_web_harness",
      "path": "app/rams_open_web_harness"
    },
    {
      "name": "rams_annotation_harness",
      "path": "app/rams_annotation_harness"
    },
    {
      "name": "rams_briefing_harness",
      "path": "app/rams_briefing_harness"
    },
    {
      "name": "rams_review_harness",
      "path": "app/rams_review_harness"
    }
  ],
  "datasets": [],
  "payments": []
}
