# Backend
APP_ENV=local
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
APP_ACCESS_TOKEN_HASH=
APP_ACCESS_CODE_LABEL=local-dev
ENABLE_BEDROCK=false
AWS_PROFILE=your-local-aws-profile
AWS_REGION=your-aws-region
BEDROCK_MODEL_ID=your-enabled-bedrock-model-id
BEDROCK_MAX_TOKENS=1200
BEDROCK_TEMPERATURE=0.2
BEDROCK_MAX_MODEL_CALLS=2
BEDROCK_PLANNER_MAX_TOKENS=900
BEDROCK_REASONER_MAX_TOKENS=1500
BEDROCK_COMPILER_MAX_TOKENS=2200
DURABLE_RUN_MAX_TOOL_CALLS=12
DURABLE_RUN_TIMEOUT_SECONDS=45
DURABLE_RUN_PROCESS_INLINE=false
S3_UPLOAD_BUCKET=
DYNAMODB_SESSION_TABLE=
UPLOAD_RETENTION_DAYS=7
SESSION_RETENTION_DAYS=7
ENABLE_AGENTCORE_RUNTIME=false
AGENTCORE_RUNTIME_ARN=
ENABLE_AGENTCORE_MEMORY=false
AGENTCORE_MEMORY_ID=
ENABLE_GEOAPIFY_GEOCODING=false
GEOAPIFY_API_KEY=
GEOAPIFY_GEOCODING_LIMIT=3
GEOAPIFY_GEOCODING_TIMEOUT_SECONDS=4
ENABLE_LIVE_MAP_FEATURES=false
LIVE_MAP_REQUIRED=false
LIVE_FEATURE_RADIUS_METERS=350
OVERPASS_API_URL=https://overpass-api.de/api/interpreter
PLANNING_DATA_API_BASE=https://www.planning.data.gov.uk
# Test-only switches. Do not enable in normal demo runs.
BEDROCK_MOCK_RESPONSE=false
BEDROCK_SIMULATE_FAILURE=false

# Frontend
# Leave blank for Vite dev proxy in local/Codespaces development.
VITE_API_BASE_URL=
# Browser-visible public Cesium ion token. Restrict allowed URLs/scopes in Cesium ion.
VITE_CESIUM_ION_TOKEN=
